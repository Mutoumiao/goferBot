{
  "name": "@goferbot/webui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others 'pnpm vite:dev' 'pnpm devtools'",
    "vite:dev": "cross-env DEBUG=0 vite",
    "devtools": "vue-devtools",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config tests/e2e/playwright.config.ts --ui",
    "test:e2e:codegen": "playwright codegen --config tests/e2e/playwright.config.ts http://localhost:1420",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e:full": "playwright test --config tests/e2e-full/playwright.config.ts",
    "test:all": "vitest run && pnpm test:integration && playwright test --config tests/e2e/playwright.config.ts",
    "type-check": "vue-tsc --noEmit",
    "tauri": "tauri"
  },
  "dependencies": {
    "@goferbot/shell-adapters": "workspace:*",
    "@goferbot/backend-adapters": "workspace:*",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@vue/devtools": "^8.0.5",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.27"
  },
  "devDependencies": {
    "@egoist/tailwindcss-icons": "^1.9.2",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify/types": "^2.0.0",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2.10.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/lodash-es": "^4.17.12",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.2.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-vue": "^10.7.0",
    "happy-dom": "^20.9.0",
    "lodash-es": "^4.17.23",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4"
  }
}
