# 运行环境: development | production
NODE_ENV=development

# Sidecar 服务端口
PORT=3000

# 数据库连接
DATABASE_URL=postgresql://user:password@localhost:5432/goferbot

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-long
BETTER_AUTH_URL=http://localhost:3000

# CORS 来源（开发默认 localhost:1420，生产需配置实际 Tauri origin）
CORS_ORIGIN=http://localhost:1420

# 速率限制存储: memory | redis
# 开发使用 memory，生产建议 redis 以支持多实例共享计数
RATE_LIMIT_STORAGE=memory

# Redis 连接（仅当 RATE_LIMIT_STORAGE=redis 时必填）
REDIS_URL=redis://localhost:6379
