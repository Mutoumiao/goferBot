# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goferbot

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=goferbot-files

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Settings Encryption (strongly recommended — do NOT rely on JWT_SECRET derivation)
# Generate with: openssl rand -base64 32
SETTINGS_ENCRYPTION_KEY=

# CORS
CORS_ORIGIN=http://localhost:5173

# 测试大模型
DEEPSEEK_API_KEY=example-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX=knowledge_chunks

# Reranker（重排序模型）
# 重要：RERANK_MODEL 必须以允许列表中的前缀开头，否则服务将拒绝加载并回退到安全默认值
# （BAAI/bge-reranker-v2-m3）。允许的前缀如下：
#   - BAAI/               （BAAI 官方重排序模型，例如 bge-reranker-v2-m3）
#   - Xorbits/            （Xorbits 托管的重排序变体）
#   - sentence-transformers/ （HuggingFace sentence-transformers 家族）
# 此白名单用于防止通过环境变量意外或恶意注入供应链。
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_MAX_LENGTH=512

# RAG LLM
RAG_LLM_API_KEY=
RAG_LLM_MODEL=gpt-3.5-turbo
RAG_LLM_BASE_URL=
RAG_LLM_TIMEOUT_MS=60000

# RAG Features
RAG_CONTEXTUAL_EMBEDDING=true
RAG_CONTEXTUAL_WINDOW=1
RAG_PARENT_CHUNK_SIZE=800
RAG_CHILD_CHUNK_SIZE=150

# RAG 元数据过滤器白名单（参考 — 详见 src/processors/rag/dto/rag.schema.ts）
# 传入的 metadata 键名将根据此允许列表进行校验。任何不在列表中的键名，
# 或以保留前缀（__ $ .）开头的键名，都将在 DTO 层被拒绝，以防止 NoSQL 注入。
# 当前允许列表：
#   year（年份）, status（状态）, type（类型）, category（分类）, source（来源）,
#   language（语言）, author（作者）, priority（优先级）, department（部门）,
#   project（项目）, tags（标签）, version（版本）
METADATA_ALLOWED_KEYS=year,status,type,category,source,language,author,priority,department,project,tags,version
