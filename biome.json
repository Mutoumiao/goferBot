{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "master"
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.cjs",
      "**/*.css",
      "**/*.json",
      "!!**/dist",
      "!!**/coverage",
      "!!**/test-results",
      "!!**/playwright-report",
      "!!**/.data",
      "!!**/*.gen.ts",
      "!!**/routeTree.gen.ts",
      "!!packages/webui",
      "!!**/prisma/migrations",
      "!!**/docs",
      "!!**/node_modules"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noControlCharactersInRegex": "off",
        "noArrayIndexKey": "warn"
      },
      "correctness": {
        "useExhaustiveDependencies": "warn"
      },
      "a11y": {
        "noStaticElementInteractions": "warn",
        "useKeyWithClickEvents": "warn"
      },
      "complexity": {
        "noBannedTypes": "warn"
      }
    },
    "domains": {
      "react": "recommended",
      "test": "recommended"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all",
      "arrowParentheses": "always",
      "bracketSpacing": true
    },
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "json": {
    "formatter": {
      "indentStyle": "space",
      "indentWidth": 2
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["packages/server/**"],
      "linter": {
        "rules": {
          "style": {
            "useImportType": "off"
          },
          "complexity": {
            "noBannedTypes": "off",
            "noUselessConstructor": "off",
            "noStaticOnlyClass": "off"
          },
          "correctness": {
            "useHookAtTopLevel": "off",
            "useYield": "off"
          },
          "suspicious": {
            "useIterableCallbackReturn": "off",
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/admin/**"],
      "linter": {
        "rules": {
          "a11y": "off",
          "suspicious": {
            "noExplicitAny": "off",
            "noRedeclare": "warn",
            "useIterableCallbackReturn": "off"
          },
          "correctness": {
            "useExhaustiveDependencies": "off",
            "useHookAtTopLevel": "off",
            "noUnusedImports": "warn",
            "noUnusedVariables": "warn"
          },
          "complexity": {
            "noUselessTernary": "off",
            "useOptionalChain": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/web/**"],
      "linter": {
        "rules": {
          "a11y": "off",
          "suspicious": {
            "noExplicitAny": "warn",
            "noRedeclare": "warn",
            "noArrayIndexKey": "warn"
          },
          "correctness": {
            "useExhaustiveDependencies": "off",
            "useHookAtTopLevel": "off",
            "noUnusedImports": "warn",
            "noUnusedVariables": "warn"
          },
          "complexity": "off"
        }
      }
    },
    {
      "includes": [
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/*.test.ts",
        "**/*.test.tsx",
        "tests/**",
        "e2e/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off",
            "noExplicitAny": "off"
          },
          "correctness": {
            "useHookAtTopLevel": "off",
            "useYield": "off",
            "noUnusedFunctionParameters": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.config.ts", "**/*.config.cjs", "scripts/**", "*.cjs"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["e2e/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off",
            "noExplicitAny": "off"
          },
          "correctness": {
            "noUnusedVariables": "warn",
            "noUnusedImports": "warn"
          }
        }
      }
    }
  ]
}
