{
  "name": "@goferbot/root",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @goferbot/webui dev",
    "build": "pnpm -r build",
    "test": "vitest",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "pnpm test && pnpm test:integration && pnpm test:e2e",
    "type-check": "pnpm -r type-check",
    "preview": "pnpm --filter @goferbot/webui preview",
    "tauri": "pnpm --filter @goferbot/webui tauri",
    "check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "bump": "node bump-version.cjs"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "happy-dom": "^20.9.0",
    "lodash-es": "^4.17.23",
    "pinia": "^3.0.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vue": "^3.5.27"
  }
}
