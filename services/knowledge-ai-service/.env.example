# Shared service token (Nest → Knowledge AI). Required.
KNOWLEDGE_AI_SERVICE_TOKEN=change-me-in-dev

# Same PG instance as GoferBot business DB; knowledge schema is isolated.
DATABASE_URL=postgresql://gofer:gofer_dev_pass@127.0.0.1:5432/goferbot

# Elasticsearch (BM25 full-text only; no dense vector as primary store)
ELASTICSEARCH_URL=http://127.0.0.1:9200
ELASTICSEARCH_INDEX=knowledge_chunks

# Vector column dim — must match embedding model output (BGE-large-zh / bge-m3 often 1024)
# Docker Compose: set EMBEDDING_DIMENSION in the host env used to start compose (default was 1536)
EMBEDDING_DIMENSION=1024

# Optional Langfuse (pluggable; service runs without these)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Server
HOST=127.0.0.1
PORT=8090
LOG_LEVEL=info
