# Shared service token (Nest → Knowledge AI). Required.
KNOWLEDGE_AI_SERVICE_TOKEN=change-me-in-dev

# Same PG instance as GoferBot business DB; knowledge schema is isolated.
DATABASE_URL=postgresql://gofer:gofer_dev_pass@localhost:5432/goferbot

# Elasticsearch (BM25 full-text only; no dense vector as primary store)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=knowledge_chunks

# Optional: embedding dimension must match provider embedding model (Phase 1 default 1536)
EMBEDDING_DIMENSION=1536

# Optional Langfuse (pluggable; service runs without these)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Server
HOST=0.0.0.0
PORT=8090
LOG_LEVEL=info
