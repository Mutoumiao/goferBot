# ==========================================
# GoferBot 统一环境变量模板
#
# 本文件是项目唯一的完整环境变量示例（.env.example）。
# 本地开发或部署时，请将本文件复制为根目录 .env 并按需修改。
#
# 加载顺序（服务端）：
#   packages/server/.env → 根目录 .env
# 即：根目录 .env 会覆盖 packages/server/.env 中的同名变量。
#
# 配置中心迁移计划：
#   除基础设施与全局安全策略外，LLM / Embedding / RAG / Reranker 等模型配置
#   将逐步迁移到数据库配置中心，通过 UI 后台管理。
#   详见 docs/guide/backend/configuration-guide.md
#
# 前端独立配置：
#   packages/web/.env.example
#   packages/admin/.env.example
# ==========================================

# ==========================================
# 服务基础配置
# 影响服务启动与全局行为，必须保留在环境变量
# ==========================================

# 服务端口号，Fastify 监听端口
PORT=3000

# 运行环境：development / production / test
# 影响 CORS 策略、安全头、错误详情返回、Swagger 文档开关
NODE_ENV=development

# 日志级别：debug / info / warn / error
# 生产环境建议设为 info 或 warn
LOG_LEVEL=debug

# ==========================================
# Docker Compose 基础设施配置
# 以下变量同时用于 docker-compose.dev.yml 与服务端应用连接
# ==========================================

# --- PostgreSQL ---

# PostgreSQL 服务主机地址
POSTGRES_HOST=localhost

# PostgreSQL 服务监听端口，映射到宿主机
POSTGRES_PORT=5432

# PostgreSQL 初始化用户名
POSTGRES_USER=gofer

# PostgreSQL 初始化密码
POSTGRES_PASSWORD=gofer_dev_pass

# PostgreSQL 初始化数据库名
POSTGRES_DB=goferbot

# 应用连接串，Prisma 与 pgvector 共用
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# 注意：当 PostgreSQL 运行在 Docker 中时，开发环境可能需要用 localhost
# 生产环境应使用服务名或内部网络地址
DATABASE_URL=postgresql://gofer:gofer_dev_pass@localhost:5432/goferbot

# 测试数据库管理连接串，用于创建/删除测试数据库，需要超级用户权限
TEST_DATABASE_ADMIN_URL=postgresql://gofer:gofer_dev_pass@localhost:5432/postgres

# --- MinIO ---

# MinIO 服务监听端口（S3 API）
MINIO_PORT=9000

# MinIO 控制台端口
MINIO_CONSOLE_PORT=9001

# MinIO 根账号（仅用于登录 MinIO 控制台）
MINIO_ROOT_USER=minioadmin

# MinIO 根密码（仅用于登录 MinIO 控制台）
MINIO_ROOT_PASSWORD=minioadmin

# MinIO 服务端点，应用使用
MINIO_ENDPOINT=http://localhost:9000

# MinIO Access Key，应用使用
MINIO_ACCESS_KEY=minioadmin

# MinIO Secret Key，应用使用
MINIO_SECRET_KEY=minioadmin

# MinIO 默认桶名，应用使用
MINIO_BUCKET=goferbot-files

# MinIO 区域
MINIO_REGION=us-east-1

# --- Redis ---

# Redis 服务主机地址
REDIS_HOST=localhost

# Redis 服务端口
REDIS_PORT=6379

# Redis 密码，无密码时留空
REDIS_PASSWORD=

# --- Elasticsearch ---

# Elasticsearch 节点地址
ELASTICSEARCH_NODE=http://localhost:9200

# Elasticsearch API Key（优先使用）
ELASTICSEARCH_API_KEY=

# Elasticsearch 用户名（未使用 API Key 时生效）
ELASTICSEARCH_USERNAME=

# Elasticsearch 密码（未使用 API Key 时生效）
ELASTICSEARCH_PASSWORD=

# Elasticsearch 索引名，用于存储文档分片
ELASTICSEARCH_INDEX=knowledge_chunks

# ==========================================
# JWT 与认证安全
# 属于全局安全策略，必须保留在环境变量
# ==========================================

# JWT 访问令牌密钥，用于签名 access token
# 生产环境必须修改，建议执行：openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT 刷新令牌密钥，用于签名 refresh token
# 必须与 JWT_SECRET 不同，生产环境必须修改
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# JWT 访问令牌有效期
JWT_EXPIRES_IN=15m

# JWT 刷新令牌有效期
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# 配置加密
# 用于加密数据库配置中心中的 API Key 等敏感信息
# ==========================================

# 配置加密密钥，强烈建议单独设置，不要复用 JWT_SECRET
# 生成方式：openssl rand -base64 32
SETTINGS_ENCRYPTION_KEY=

# bcrypt 密码哈希轮数，数值越大越安全但越慢
# 开发环境 10-12，生产环境 12-14
BCRYPT_SALT_ROUNDS=12

# ==========================================
# CORS 与网络安全
# ==========================================

# 前端应用地址，用于 CORS 白名单，多个来源用逗号分隔
CORS_ORIGIN=http://localhost:5173

# SSRF 防护允许的主机名白名单
# 限制用户可配置的 Base URL 只能指向这些主机，防止内网探测
# 多个值用逗号分隔，例如：api.openai.com,api.deepseek.com
SSRF_ALLOWED_HOSTNAMES=

# ==========================================
# 队列配置
# ==========================================

# BullMQ 任务并发数，控制同时执行的后台任务数量
QUEUE_CONCURRENCY=2

# ==========================================
# 元数据安全策略
# 限制 RAG metadata 过滤器的可用键名，防止 NoSQL 注入
# ==========================================

# 当前允许：year, status, type, category, source, language, author, priority, department, project, tags, version
METADATA_ALLOWED_KEYS=year,status,type,category,source,language,author,priority,department,project,tags,version

# ==========================================
# 实例级行为开关
# ==========================================

# 本地 Reranker 模型是否在启动时预加载
# true 时启动会变慢，但首次请求延迟更低
RERANK_EAGER_LOAD=false

# ==========================================
# 过渡期保留：大模型与 RAG 配置（待迁移到配置中心）
#
# 说明：以下变量将在后续迭代中迁移到数据库配置中心。
# 当前代码仍依赖它们，新部署时需要先填写，否则对应功能无法使用。
# 迁移完成后，本区域将整体删除。
# 详细规划见 docs/guide/backend/configuration-guide.md
# ==========================================

# --- 测试大模型（内置 DeepSeek Provider）---
# 迁移目标：app_config.providers.deepseek
DEEPSEEK_API_KEY=example-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- 通用 LLM 配置 ---
# 迁移目标：app_config.providers
LLM_API_KEY=
LLM_MODEL=gpt-3.5-turbo
LLM_BASE_URL=
LLM_TIMEOUT_MS=60000

# --- RAG 生成模型配置 ---
# 迁移目标：app_config.ragProvider
RAG_LLM_API_KEY=
RAG_LLM_MODEL=gpt-3.5-turbo
RAG_LLM_BASE_URL=
RAG_LLM_TIMEOUT_MS=60000

# --- Embedding 模型配置 ---
# 迁移目标：app_config.embeddingProvider
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSIONS=1536

# --- Reranker 配置 ---
# 迁移目标：app_config.rerankConfig
# 重要：RERANK_MODEL 必须以允许列表中的前缀开头，否则服务将拒绝加载并回退到安全默认值
# 允许的前缀：BAAI/、Xorbits/、sentence-transformers/
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_MAX_LENGTH=512

# --- RAG 切分与上下文策略 ---
# 迁移目标：app_config.ragIndexingConfig
RAG_CONTEXTUAL_EMBEDDING=true
RAG_CONTEXTUAL_WINDOW=1
RAG_PARENT_CHUNK_SIZE=800
RAG_CHILD_CHUNK_SIZE=150

# --- RAG 同义词扩展字典 ---
# 迁移目标：app_config.ragIndexingConfig.synonymDict
# 格式为 JSON，例如：{"ai":["人工智能","artificial intelligence"]}
RAG_SYNONYM_DICT=

# --- 启用的内置聊天 Provider ---
# 迁移目标：由 app_config.defaultChatProvider 取代
ENABLED_PROVIDERS=deepseek

# ==========================================
# 待清理：当前未启用但代码中保留读取的变量
# 如果确认不使用 RSA 密码加密，可忽略
# ==========================================
RSA_PRIVATE_KEY=
RSA_PUBLIC_KEY=
