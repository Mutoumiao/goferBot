# ==========================================
# GoferBot 根目录环境变量模板
#
# 单一信息源原则：
#   - 本文件是 Docker-Infra 与 Shared 变量的唯一信息源
#     · Docker-Infra: docker-compose.dev.yml 需要的基础设施变量
#     · Shared:       server 应用与基础设施共用的连接参数
#   - Server-Only 变量的单一信息源为 packages/server/.env.example
#     （PORT / NODE_ENV / JWT_* / CORS_ORIGIN / SSRF_ALLOWED_HOSTNAMES 等）
#   - 前端 Vite 变量的单一信息源为 packages/web/.env.example
#     与 packages/admin/.env.example
#
# 加载顺序（后加载覆盖前者同名变量）：
#   1. packages/server/.env   — Server-Only
#   2. 根目录 .env            — Docker-Infra + Shared
#
# 完整变量分类与说明见 docs/guide/backend/configuration-guide.md
# ==========================================

# ==========================================
# Docker Compose 基础设施配置
# 以下变量由 docker-compose.dev.yml 直接读取
# ==========================================

# --- PostgreSQL ---

# PostgreSQL 服务主机地址
POSTGRES_HOST=localhost

# PostgreSQL 服务监听端口，映射到宿主机
POSTGRES_PORT=5432

# PostgreSQL 初始化用户名
POSTGRES_USER=gofer

# PostgreSQL 初始化密码
POSTGRES_PASSWORD=gofer_dev_pass

# PostgreSQL 初始化数据库名
POSTGRES_DB=goferbot

# --- MinIO ---

# MinIO 服务监听端口（S3 API）
MINIO_PORT=9000

# MinIO 控制台端口
MINIO_CONSOLE_PORT=9001

# MinIO 根账号（仅用于登录 MinIO 控制台）
MINIO_ROOT_USER=minioadmin

# MinIO 根密码（仅用于登录 MinIO 控制台）
MINIO_ROOT_PASSWORD=minioadmin

# --- Redis ---

# Redis 服务端口
REDIS_PORT=6379

# ==========================================
# Shared: 应用连接基础设施的参数
# server 应用通过 ConfigModule 读取这些值
# ==========================================

# 应用连接串，Prisma 与 pgvector 共用
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# 注意：当 PostgreSQL 运行在 Docker 中时，开发环境可能需要用 127.0.0.1
#（Windows 上 Prisma engine 对 localhost 的 IPv6 解析可能与 Docker 端口映射不兼容）
# 生产环境应使用服务名或内部网络地址
DATABASE_URL=postgresql://gofer:gofer_dev_pass@127.0.0.1:5432/goferbot

# 测试数据库管理连接串，用于创建/删除测试数据库，需要超级用户权限
TEST_DATABASE_ADMIN_URL=postgresql://gofer:gofer_dev_pass@127.0.0.1:5432/postgres

# Redis 服务主机地址
REDIS_HOST=localhost

# Redis 密码，无密码时留空
REDIS_PASSWORD=

# MinIO 服务端点，应用使用
MINIO_ENDPOINT=http://localhost:9000

# MinIO Access Key，应用使用
MINIO_ACCESS_KEY=minioadmin

# MinIO Secret Key，应用使用
MINIO_SECRET_KEY=minioadmin

# MinIO 默认桶名，应用使用
MINIO_BUCKET=goferbot-files

# MinIO 区域
MINIO_REGION=us-east-1

# Elasticsearch 节点地址
ELASTICSEARCH_NODE=http://localhost:9200

# Elasticsearch API Key（优先使用）
ELASTICSEARCH_API_KEY=

# Elasticsearch 用户名（未使用 API Key 时生效）
ELASTICSEARCH_USERNAME=

# Elasticsearch 密码（未使用 API Key 时生效）
ELASTICSEARCH_PASSWORD=

# Elasticsearch 索引名，用于存储文档分片
ELASTICSEARCH_INDEX=knowledge_chunks

# ==========================================
# 邀请码配置
# ==========================================

# 万能测试邀请码，逗号分隔多个码，可选，不入数据库
# 示例：TEST_INVITATION_CODES=TEST-CODE-001,TEST-CODE-002
TEST_INVITATION_CODES=